# ---- LLM (LangChain) ----
# Powers the synthesis node, ticker disambiguation, and the low-confidence sentiment
# fallback. If no key is set, the pipeline still runs on FinBERT alone.
# Provider: "auto" uses OpenAI when OPENAI_API_KEY is set, else Anthropic. Force with
# "openai" / "anthropic".
MS_LLM_PROVIDER=auto
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model — leave blank for the provider default (openai=gpt-4o-mini, anthropic=claude-opus-4-8).
# gpt-4o-mini is the cost/quality sweet spot; upgrading rarely helps (see the eval).
MS_LLM_MODEL=

# ---- Sources ----
# StockTwits: many endpoints are public but rate-limited; a token raises limits.
MS_STOCKTWITS_ACCESS_TOKEN=

# Reddit (optional — the reddit source is a stub until you wire PRAW)
MS_REDDIT_CLIENT_ID=
MS_REDDIT_CLIENT_SECRET=
MS_REDDIT_USER_AGENT=market-sentiment/0.1 by u_yourname

# ---- Sentiment backend: "finbert" (default) or "llm" ----
MS_SENTIMENT_BACKEND=finbert
MS_FINBERT_MODEL=ProsusAI/finbert
# Posts classified below this confidence are re-checked by the LLM (if a key is set).
MS_LOW_CONFIDENCE_THRESHOLD=0.55

# ---- Aggregation / "hot stocks" detection ----
MS_HOT_MIN_MENTIONS=5
MS_HOT_TOP_N=10

# ---- Storage ----
MS_DB_PATH=data/marketsentiment.duckdb

# ---- LangSmith tracing (optional but recommended) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=market-sentiment
